# ── LLM provider: "ollama" (mặc định) hoặc "anthropic" (fallback) ──
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──
DATABASE_URL=sqlite:///./shopstyle.db

# ── Auth (dùng placeholder — KHÔNG commit secret thật) ──
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Defense toggle — false = vulnerable (baseline), true = hardened ──
DEFENSE_ACTIVE=false
# Baseline có ranh giới vai trò cho kịch bản jailbreak
JAILBREAK_SCENARIO=false
